{\n  "manifest_version": 2,\n  "name": "SoftTech Password Manager",\n  "version": "1.0",\n  "description": "A browser extension to manage your passwords securely.",\n  "permissions": [\n    "storage",\n    "tabs",\n    "activeTab"\n  ],\n  "background": {\n    "scripts": ["background.js"],\n    "persistent": false\n  },\n  "content_scripts": [{\n    "matches": ["<all_urls>"],\n    "js": ["content.js"]\n  }],\n  "browser_action": {\n    "default_popup": "popup.html",\n    "default_icon": "icon.png"\n  },\n  "icons": {\n    "48": "icon.png"\n  }\n}